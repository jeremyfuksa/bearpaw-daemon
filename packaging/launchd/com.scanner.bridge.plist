<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.scanner.bridge</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/scanner-bridge</string>
    <string>--config</string>
    <string>/usr/local/etc/scanner-bridge/config.yaml</string>
    <string>--daemon</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
</dict>
</plist>
